# -----------------------------------------------
# Cascade — environment variable template
# Copy this file to .env and fill in your values
# -----------------------------------------------

# Required: shared secret that must be sent with every /ask-ai request
MY_APP_SECRET=your-secret-here

# API keys for each provider
# Multiple keys can be pipe-separated for automatic rotation: keyA|keyB|keyC
GEMINI_KEY=your-gemini-key
GROQ_KEY=your-groq-key
MISTRAL_KEY=your-mistral-key
CEREBRAS_KEY=your-cerebras-key

# Server port (default: 10000 — Render sets this automatically, don't change unless running locally)
# PORT=10000

# Per-request provider timeout in milliseconds (default: 15000)
# PROVIDER_TIMEOUT_MS=15000

# Rate limiting — max requests per window per IP (defaults: 30 requests per 60s)
# RATE_LIMIT_MAX=30
# RATE_LIMIT_WINDOW_MS=60000
